# ls shortcuts
alias ll="ls -l"
alias la="ls -al"
alias lt="ls -ltr"

# vagrant shortcuts
alias vvup="vagrant up"
alias vvprovision="vagrant provision"
alias vvssh="vagrant ssh"
alias vvhalt="vagrant halt"
alias vvdestroy="vagrant destroy"

# functions
function ps_kill {
	ps aux | grep -ie $1 | awk '{print $2}' | xargs kill -9 
}
