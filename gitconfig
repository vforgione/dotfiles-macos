[user]
	name = Vince Forgione
	email = v.forgione@gmail.com
	identityfile = ~/.ssh/id_rsa

[color]
	ui = true
	diff = true

[alias]
	prune = fetch --prune
	undo = reset --soft HEAD^
	stash-all = stash save --include-untracked
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short

[status]
	showUntrackedFiles = all
