[user]
    name = Vince Forgione
    email = vince.4gione@icloud.com
    identitfyfile = ~/.ssh/id_rsa
    signingkey =

[color]
    ui = true
    diff = true

[alias]
    prune = fetch --prune
    undo = reset --soft ^HEAD
    stash-all = stash save --include-untracked

[status]
    showUntrackedFiles = all

[commit]
    gpgsign = true

[core]
    editor = vim

[gpg]
    program = /usr/local/bin/gpg
